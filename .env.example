# Copy to .env and fill in values

# "local" uses HuggingFace transformers (MPS on Apple Silicon, CUDA on Linux, CPU fallback)
# "vllm" calls a running vLLM OpenAI-compatible server
INFERENCE_BACKEND=local

# Compute device for local inference: "auto" (default) probes MPS → CUDA → CPU
# Override: DEVICE=mps | cuda | cpu
DEVICE=auto

DATABASE_URL=sqlite+aiosqlite:///./eval_engine.db
REDIS_URL=redis://localhost:6379/0

# Only needed for inference_backend=vllm
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=token
VLLM_DEFAULT_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Local model (only needed for inference_backend=local)
LOCAL_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct

# Active learning thresholds
HUMAN_REVIEW_LOWER=0.45
HUMAN_REVIEW_UPPER=0.65
LORA_RETRAIN_THRESHOLD=0.95
LORA_RETRAIN_WINDOW=100

# SF image generation via local Flux.1 (requires local-flux extras + huggingface-cli login)
# Set GENERATE_SF_IMAGE=false to disable and skip model download
GENERATE_SF_IMAGE=true
FLUX_MODEL_ID=black-forest-labs/FLUX.1-schnell
# FLUX_NUM_STEPS=4          # default: 4 for schnell, 20 for dev
# FLUX_GUIDANCE_SCALE=0.0   # default: 0.0 for schnell, 3.5 for dev
FLUX_IMAGE_WIDTH=1024
FLUX_IMAGE_HEIGHT=1024
